#!/bin/sh

# Enforce a concise, informative first line:
#   Verb + What Changed

set -eu

MSG_FILE="${1:-}"
[ -n "$MSG_FILE" ] || exit 0
[ -f "$MSG_FILE" ] || exit 0

subject="$(
  sed -n '/^[[:space:]]*#/d; /^[[:space:]]*$/d; 1p' "$MSG_FILE" \
    | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
)"

[ -n "$subject" ] || exit 0

# Ignore merge/revert/autogenerated commits.
case "$subject" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

is_bad=0

# Require at least two words.
word_count="$(printf '%s\n' "$subject" | awk '{print NF}')"
if [ "${word_count:-0}" -lt 2 ]; then
  is_bad=1
fi

# Reject vague subjects that don't explain user-visible intent.
if printf '%s\n' "$subject" | grep -Eiq '^(update|change|misc|wip|stuff|tmp|test)([[:space:]]+[0-9]+[[:space:]]+files?)?$'; then
  is_bad=1
fi
if printf '%s\n' "$subject" | grep -Eiq '^(update|change)[[:space:]]+[0-9]+[[:space:]]+files?$'; then
  is_bad=1
fi

# Encourage leading verb.
if ! printf '%s\n' "$subject" | grep -Eq '^[A-Z][a-z]+'; then
  is_bad=1
fi

if [ "$is_bad" -ne 0 ]; then
  cat >&2 <<'EOF'
Commit message subject is too vague.
Use: Verb + What Changed
Examples:
  Add Task View context navigation
  Fix inbox selection in Tasks View
  Update release notes generation in bump.py
EOF
  exit 1
fi

exit 0
